{
  "expo": {
    "name": "Nick's Recipes",
    "slug": "nicks-recipes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/recipe.png",
    "scheme": "nicksrecipes",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "icon": "./assets/images/recipe.png",
      "predictiveBackGestureEnabled": false,
      "package": "com.ngmangos.nicksrecipes"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/recipe.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/recipe.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30302e31-9b3d-43fc-acf9-9e9a2e6a33d2"
      }
    }
  }
}
